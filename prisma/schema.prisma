// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Custom scheduling fields
  username         String?   @unique
  availableStart   String    @default("09:00")
  availableEnd     String    @default("17:00")
  availableDays    String    @default("1,2,3,4,5")
  duration         Int       @default(30)
  location         String    @default("Google Meet")
  allowOtherLocation Boolean   @default(false)
  monthsUpfront    Int       @default(3)
  dateOverrides    Json?
  emailConfirmationMsg String?   @db.Text
  emailCancellationMsg String?   @db.Text
  createdAt        DateTime  @default(now())
  bookings       Booking[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Booking {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  guestName       String
  guestEmail      String
  date            DateTime @db.Date // The day of the booking
  time            String   // Time slot like "13:00"
  location        String   @default("Google Meet")
  locationDetails String?  @db.Text
  status          String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  cancelledAt     DateTime?
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())

  @@unique([userId, date, time])
}
